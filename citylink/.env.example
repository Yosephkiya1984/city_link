# CityLink Environment Configuration
# Copy this file to .env and fill in your values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Development Settings
EXPO_PUBLIC_DEV_MODE=false
EXPO_PUBLIC_OTP_BYPASS=false

# IMPORTANT: Admin code should NOT use EXPO_PUBLIC_ prefix in production.
# It will be inlined into the client bundle. Move to server-side validation.
# EXPO_PUBLIC_ADMIN_CODE=your-admin-code
