# CityLink Environment Variables Example
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Chapa Payment Gateway
EXPO_PUBLIC_CHAPA_KEY=CHAPUBK_TEST-your-chapa-key

# Application Configuration
EXPO_PUBLIC_ADMIN_CODE=your-admin-code
EXPO_PUBLIC_AI_PROXY_URL=https://your-ai-proxy-url.com
EXPO_PUBLIC_DEV_MODE=false
EXPO_PUBLIC_OTP_BYPASS=false

# Error Tracking (Optional)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
