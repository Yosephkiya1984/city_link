{
  "expo": {
    "name": "CityLink",
    "slug": "citylink",
    "scheme": "citylink",
    "version": "2.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B10"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.citylink.addis",
      "infoPlist": {
        "NSCameraUsageDescription": "CityLink uses your camera to scan QR codes for tickets and parking.",
        "NSLocationWhenInUseUsageDescription": "CityLink uses your location to find nearby parking and services."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#080B10"
      },
      "package": "com.citylink.addis",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {},
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CityLink to use the camera for QR scanning."
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
